# Copy this file's contents into real environment variables before running.
# Never commit your actual keys/passwords to git -- this file is just a template.

# Groq API key (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Gmail address used to send notifications
GMAIL_ADDRESS=your-email@example.com

# Gmail App Password (NOT your normal Gmail password)
# Create one at https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be turned on first
GMAIL_APP_PASSWORD=your-app-password-here

# Optional: where notification emails get sent. Defaults to GMAIL_ADDRESS if not set.
NOTIFY_EMAIL=your-email@example.com

API_BASE_URL=https://your-app.azurewebsites.net
API_KEY=your-api-key-here

# Neon PostgreSQL connection string (used by database.py / audit_log.py).
# Get this from your Neon project dashboard -> Connection Details ->
# "Connection string" (choose the pooled connection for serverless use).
# Must use the postgresql+psycopg2 dialect prefix and keep sslmode=require --
# Neon rejects non-TLS connections.
DATABASE_URL=postgresql+psycopg2://neondb_owner:your-password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
